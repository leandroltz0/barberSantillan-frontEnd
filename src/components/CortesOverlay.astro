---
---
<section id="cortes">
  <div class="cortes-header-bar">
    <div><div class="header-logo"><img src="/logo.png" alt="Santillán" class="logo-img"></div></div>
    <button class="cortes-overlay-close" id="cortesClose" aria-label="Cerrar">✕</button>
  </div>
  <div class="cortes-sticky" id="cortesScroll">
    <div class="cortes-track">
      <div class="cortes-card"><div class="cortes-card-img-placeholder"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.08)" stroke-width="1"><rect x="8" y="6" width="32" height="36" rx="2" opacity=".4"></rect><path d="M16 22 q16-8 16 0" opacity=".25"></path></svg></div></div>
      <div class="cortes-card"><div class="cortes-card-img-placeholder"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.08)" stroke-width="1"><rect x="8" y="6" width="32" height="36" rx="2" opacity=".4"></rect><path d="M14 20 L24 14 L34 20 M24 14 v16" stroke-linecap="round" opacity=".25"></path></svg></div></div>
      <div class="cortes-card"><div class="cortes-card-img-placeholder"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.08)" stroke-width="1"><rect x="8" y="6" width="32" height="36" rx="2" opacity=".4"></rect><path d="M16 16 q8 12 16 0" opacity=".25"></path><path d="M20 28 q4-6 8 0" opacity=".2"></path></svg></div></div>
      <div class="cortes-card"><div class="cortes-card-img-placeholder"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.08)" stroke-width="1"><rect x="8" y="6" width="32" height="36" rx="2" opacity=".4"></rect><circle cx="24" cy="18" r="6" opacity=".25"></circle><path d="M18 30 q6-8 12 0" opacity=".2"></path></svg></div></div>
      <div class="cortes-card"><div class="cortes-card-img-placeholder"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.08)" stroke-width="1"><rect x="8" y="6" width="32" height="36" rx="2" opacity=".4"></rect><path d="M12 12 L24 8 L36 12 M24 8 v18" stroke-linecap="round" opacity=".25"></path><path d="M16 34 q8-6 16 0" opacity=".2"></path></svg></div></div>
      <div class="cortes-card"><div class="cortes-card-img-placeholder"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.08)" stroke-width="1"><rect x="8" y="6" width="32" height="36" rx="2" opacity=".4"></rect><path d="M20 14 L28 14 M24 14 v10" stroke-linecap="round" opacity=".25"></path><path d="M16 32 q8 4 16 0" opacity=".2"></path></svg></div></div>
      <div class="cortes-card"><div class="cortes-card-img-placeholder"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.08)" stroke-width="1"><rect x="8" y="6" width="32" height="36" rx="2" opacity=".4"></rect><path d="M14 16 q10-6 20 0" opacity=".25"></path><circle cx="24" cy="24" r="4" opacity=".2"></circle></svg></div></div>
      <div class="cortes-card"><div class="cortes-card-img-placeholder"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.08)" stroke-width="1"><rect x="8" y="6" width="32" height="36" rx="2" opacity=".4"></rect><path d="M16 20 L24 12 L32 20 M24 12 v16" stroke-linecap="round" opacity=".25"></path></svg></div></div>
      <div class="cortes-card"><div class="cortes-card-img-placeholder"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.08)" stroke-width="1"><rect x="8" y="6" width="32" height="36" rx="2" opacity=".4"></rect><path d="M12 18 L24 10 L36 18 M24 10 v20" stroke-linecap="round" opacity=".25"></path><path d="M16 36 q8-4 16 0" opacity=".2"></path></svg></div></div>
      <div class="cortes-card"><div class="cortes-card-img-placeholder"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.08)" stroke-width="1"><rect x="8" y="6" width="32" height="36" rx="2" opacity=".4"></rect><path d="M20 12 L28 12 M24 12 v14" stroke-linecap="round" opacity=".25"></path><circle cx="24" cy="30" r="4" opacity=".2"></circle></svg></div></div>
      <div class="cortes-card-end">
        <div class="cortes-end-text">Así es<br><span class="gold">mi trabajo</span></div>
        <div class="cortes-end-underline"></div>
        <button class="cortes-end-ok" id="cortesOkBtn">OK</button>
      </div>
    </div>
    <div class="cortes-end-hint">
      <svg viewBox="0 0 24 24"><polyline points="9 18 15 12 9 6" fill="none" stroke="currentColor" stroke-width="2"></polyline></svg>
      DESLIZÁ PARA VER MÁS
      <svg viewBox="0 0 24 24"><polyline points="15 6 9 12 15 18" fill="none" stroke="currentColor" stroke-width="2"></polyline></svg>
    </div>
  </div>
</section>
