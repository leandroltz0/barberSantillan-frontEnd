---

---

<section id="nosotros" class="section-padding">
  <div class="container">
    <div class="about-grid">
      <div class="about-collage">
        <div class="collage-inner">
          <div class="collage-frame"></div>
          <div class="collage-ph-1">
            <div class="collage-img">
              <svg
                viewBox="0 0 48 48"
                fill="none"
                stroke="rgba(240,236,228,.12)"
                stroke-width="1"
                ><circle cx="24" cy="16" r="8"></circle><path
                  d="M10 44c0-8 6-14 14-14s14 6 14 14"></path></svg
              >
            </div>
            <div class="collage-subject">
              <span class="collage-subject-label">El barbero</span>
              <span class="collage-subject-name">— Santillán</span>
            </div>
            <span class="collage-ph-badge coll-badge-1">FOTO</span>
          </div>
          <div class="collage-ph-2">
            <div class="collage-img">
              <img
                src="/galeria/maquinas/maquinas1.jpeg"
                alt="Herramientas de barbería"
                loading="lazy"
              />
            </div>
            <span class="collage-ph-badge coll-badge-2">HERRAMIENTAS</span>
          </div>
          <div class="collage-ph-3">
            <div class="collage-img">
              <img
                src="/galeria/certificado/certificado1-removebg-preview.png"
                alt="Certificado de barbería"
                loading="lazy"
              />
            </div>
            <span class="collage-ph-badge coll-badge-3">CERTIFICADO</span>
          </div>
        </div>
      </div>
      <div class="about-text">
        <div class="gold-label">SOBRE NOSOTROS</div>
        <h2 class="about-heading">El mejor corte para cada cliente.</h2>
        <p class="about-body">
          Trabajo desde casa, en Moreno, con una cosa clara: que cada cliente
          salga sintiéndose bien. Sin apuros, sin mal trabajo.
        </p>
        <p class="about-body">
          Empecé cortando en el barrio y crecí de boca en boca. Hoy tengo
          clientes fijos que vienen hace años — eso dice más que cualquier
          publicidad.
        </p>
        <p class="about-body">
          Cada corte es personal. Me tomo el tiempo de entender qué querés y
          cómo lo podés mantener.
        </p>
        <ul class="about-checkmarks">
          <li>Años de experiencia</li><li>Garantía de calidad</li><li>
            Barbero certificado
          </li><li>100% personalizado</li>
        </ul>
        <a href="#certificacion" class="btn btn-ghost">LEER MÁS →</a>
      </div>
    </div>
  </div>
</section>
<style>
  #nosotros {
    background: var(--bg);
    margin-bottom: 2rem;
  }
  .about-grid {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .about-text {
    order: 1;
  }
  .about-collage {
    order: 2;
  }
  .about-heading {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(42px, 6vw, 64px);
    font-weight: 600;
    color: var(--gold);
    line-height: 1.2;
    position: relative;
    padding-bottom: 12px;
    margin-bottom: 24px;
  }
  .about-heading::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 2px;
    background: var(--gold);
  }
  .about-body {
    font-family: "DM Sans", sans-serif;
    font-size: 15px;
    color: var(--muted);
    line-height: 1.85;
    margin-bottom: 16px;
  }
  .about-checkmarks {
    display: flex;
    flex-wrap: wrap;
    gap: 12px 24px;
    margin: 24px 0;
  }
  .about-checkmarks li {
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    color: var(--cream);
  }
  .about-checkmarks li::before {
    content: "✓";
    color: var(--gold);
    margin-right: 6px;
  }
  .collage-inner {
    position: relative;
    width: 100%;
    height: 712px;
    overflow: hidden;
  }
  .collage-frame {
    position: absolute;
    top: 16px;
    left: 16px;
    width: calc(62% - 16px);
    height: calc(100% - 32px);
    border: 1.5px solid rgba(201, 168, 76, 0.25);
    pointer-events: none;
    z-index: 0;
    transition: opacity 0.4s ease;
  }
  .collage-ph-1 {
    position: absolute;
    top: 0;
    left: 0;
    width: 62%;
    height: 95%;
    background: var(--surface);
    z-index: 1;
    border-right: 3px solid var(--gold);
    display: flex;
    align-items: flex-end;
    padding: 14px;
    transition:
      transform 0.5s cubic-bezier(0.23, 1, 0.32, 1),
      box-shadow 0.5s ease;
    overflow: hidden;
  }
  .collage-ph-1:hover {
    transform: scale(1.03);
    box-shadow: 0 16px 48px rgba(201, 168, 76, 0.18);
  }
  .collage-ph-1::before {
    content: "";
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(201, 168, 76, 0.08),
      transparent 50%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .collage-ph-1:hover::before {
    opacity: 1;
  }
  .collage-ph-1 .collage-img {
    position: absolute;
    inset: 0;
    background: linear-gradient(145deg, #1e1e1e, #151515);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .collage-ph-1 .collage-img svg {
    width: 56px;
    height: 56px;
    opacity: 0.12;
  }
  .collage-ph-2 {
    position: absolute;
    top: 85px;
    right: 0;
    width: 48%;
    height: 52%;
    background: #222;
    z-index: 2;
    border-bottom: 3px solid var(--gold);
    overflow: hidden;
    transition:
      transform 0.5s cubic-bezier(0.23, 1, 0.32, 1),
      box-shadow 0.5s ease;
  }
  .collage-ph-2:hover {
    transform: scale(1.04);
    box-shadow: 0 12px 36px rgba(201, 168, 76, 0.14);
  }
  .collage-ph-2 .collage-img {
    position: absolute;
    inset: 0;
    background: linear-gradient(135deg, #1c1c1c, #121212);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .collage-ph-2 .collage-img svg {
    width: 40px;
    height: 40px;
    opacity: 0.1;
  }
  .collage-ph-2 .collage-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .collage-ph-3 {
    position: absolute;
    bottom: 14px;
    right: 14px;
    width: 40%;
    height: 36%;
    background: #1c1c1c;
    z-index: 3;
    border-top: 3px solid var(--gold);
    overflow: hidden;
    transition:
      transform 0.5s cubic-bezier(0.23, 1, 0.32, 1),
      box-shadow 0.5s ease;
  }
  .collage-ph-3:hover {
    transform: scale(1.05);
    box-shadow: 0 10px 30px rgba(201, 168, 76, 0.12);
  }
  .collage-ph-3 .collage-img {
    position: absolute;
    inset: 0;
    background: linear-gradient(150deg, #191919, #111);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }
  .collage-ph-3 .collage-img svg {
    width: 32px;
    height: 32px;
    opacity: 0.1;
  }
  .collage-ph-3 .collage-img img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .collage-ph-1 .collage-subject {
    position: absolute;
    bottom: 14px;
    left: 14px;
    display: flex;
    flex-direction: column;
    z-index: 2;
  }
  .collage-subject-label {
    font-family: "DM Sans", sans-serif;
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: rgba(240, 236, 228, 0.5);
  }
  .collage-subject-name {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 20px;
    font-style: italic;
    color: rgba(240, 236, 228, 0.7);
  }
  .collage-ph-badge {
    position: absolute;
    top: 12px;
    right: 12px;
    font-family: "DM Sans", sans-serif;
    font-size: 7px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--gold);
    border: 1px solid rgba(201, 168, 76, 0.2);
    padding: 3px 8px;
    opacity: 0.6;
    white-space: nowrap;
    line-height: 1;
  }
  .collage-label {
    font-family: "DM Sans", sans-serif;
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(240, 236, 228, 0.3);
  }
  .coll-badge-1::before {
    content: "◆";
    margin-right: 4px;
    font-size: 6px;
    color: var(--gold);
  }
  .coll-badge-2::before {
    content: "✧";
    margin-right: 4px;
    font-size: 8px;
    color: var(--gold);
  }
  .coll-badge-3::before {
    content: "◈";
    margin-right: 4px;
    font-size: 7px;
    color: var(--gold);
  }
  @media (max-width: 767px) {
    .about-collage {
      width: 100%;
      max-width: 100%;
      margin-bottom: 40px;
    }
    .collage-inner {
      width: 100%;
      height: 38rem;
      aspect-ratio: 1 / 1.15;
      overflow: hidden;
    }
    .collage-ph-1,
    .collage-ph-2,
    .collage-ph-3 {
      height: auto !important;
      aspect-ratio: 1 / 1 !important;
    }
    .collage-ph-1 {
      width: 70%;
      top: 0;
      left: 0;
      padding: 12px;
      z-index: 2;
    }
    .collage-ph-2 {
      width: 50%;
      top: 22%;
      right: 0;
      z-index: 1;
    }
    .collage-ph-3 {
      width: 64%;
      bottom: 0;
      right: 8%;
      z-index: 3;
    }
    .collage-frame {
      top: 12px;
      left: 12px;
      width: calc(70% - 12px);
      height: auto !important;
      aspect-ratio: 1 / 1 !important;
    }
  }
  @media (min-width: 768px) {
    .about-grid {
      flex-direction: row;
      align-items: center;
      gap: 60px;
    }
    .about-text {
      flex: 1;
      order: 0;
    }
    .about-collage {
      flex: 1;
      order: 0;
    }
  }
</style>
