---
---
<div class="cortes-float" id="cortesFloat">
  <div class="cortes-float-label-top">
    <span>Catálogo</span>
    <strong>DE CORTES</strong>
  </div>
  <div class="cortes-float-main">
    <button class="cortes-btn-simple" id="cortesFloatBtn" aria-label="Ver Cortes">
      <i class="ph-thin ph-scissors"></i>
    </button>
    <div class="cortes-tooltip">Abrir galería</div>
  </div>
</div>

<style is:global>
  .cortes-float {
    position: fixed;
    bottom: 28px;
    left: 28px;
    z-index: 25000;
    opacity: 0;
    pointer-events: none;
    transform: translateY(20px);
    transition: opacity 0.5s ease, transform 0.5s cubic-bezier(0.23,1,0.32,1);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 12px;
  }
  
  .cortes-float.visible {
    opacity: 1;
    transform: translateY(0);
    pointer-events: auto;
  }

  .cortes-float-label-top {
    display: flex;
    flex-direction: column;
    margin-left: 4px;
    text-shadow: 0 4px 12px rgba(0,0,0,0.8);
    pointer-events: none;
  }

  .cortes-float-label-top span {
    font-family: "DM Sans", sans-serif;
    font-size: 10px;
    font-weight: 600;
    letter-spacing: 0.25em;
    color: var(--gold);
    text-transform: uppercase;
    margin-bottom: -2px;
  }

  .cortes-float-label-top strong {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 20px;
    font-weight: 600;
    letter-spacing: 0.05em;
    color: var(--cream);
  }

  .cortes-float-main {
    display: flex;
    align-items: center;
    gap: 12px;
  }
  
  .cortes-btn-simple {
    width: 60px !important;
    height: 60px !important;
    min-width: 60px !important;
    min-height: 60px !important;
    border-radius: 50% !important;
    background: var(--gold) !important;
    color: #111 !important;
    border: none !important;
    display: flex !important;
    align-items: center !important;
    justify-content: center !important;
    padding: 0 !important;
    margin: 0 !important;
    cursor: pointer;
    box-shadow: 0 8px 24px rgba(201,168,76,0.3), 0 4px 10px rgba(0,0,0,0.5);
    transition: transform 0.3s cubic-bezier(0.23,1,0.32,1), box-shadow 0.3s ease, background 0.3s ease;
    flex-shrink: 0;
  }
  
  .cortes-btn-simple:hover {
    transform: scale(1.06);
    box-shadow: 0 12px 30px rgba(201,168,76,0.4), 0 6px 15px rgba(0,0,0,0.5);
    background: #e6c15c !important;
  }
  
  .cortes-btn-simple:active {
    transform: scale(0.95);
    box-shadow: 0 4px 12px rgba(201,168,76,0.2);
  }
  
  .cortes-btn-simple i {
    font-size: 32px;
    line-height: 1;
    display: block;
    color: #111;
  }

  .cortes-float.visible .cortes-btn-simple {
    animation: floatPulseCortes 3s ease-in-out infinite;
  }
  
  .cortes-btn-simple:hover {
    animation: none !important;
  }

  @keyframes floatPulseCortes {
    0%, 100% { transform: scale(1); box-shadow: 0 8px 24px rgba(201,168,76,0.3), 0 4px 10px rgba(0,0,0,0.5); }
    50% { transform: scale(1.04); box-shadow: 0 12px 30px rgba(201,168,76,0.4), 0 6px 15px rgba(0,0,0,0.5); }
  }

  .cortes-tooltip {
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    font-weight: 500;
    color: #fff;
    background: rgba(30, 30, 30, 0.95);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255,255,255,0.15);
    border-radius: 8px;
    padding: 8px 16px;
    white-space: nowrap;
    opacity: 0;
    transform: translateX(-10px);
    transition: opacity 0.25s ease, transform 0.25s ease;
    pointer-events: none;
    box-shadow: 0 4px 15px rgba(0,0,0,0.3);
  }

  .cortes-float:hover .cortes-tooltip {
    opacity: 1;
    transform: translateX(0);
  }
</style>
