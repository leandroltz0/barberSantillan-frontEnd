---
---
<!-- === VISAGISMO OVERLAY (standalone — only on nav click) === -->
<div id="visagismoOverlay">
  <div class="visagismo-overlay-header">
    <div class="header-logo"><img src="/logo.png" alt="Santillán" class="logo-img"></div>
    <button class="visagismo-overlay-close" id="visagismoClose" aria-label="Cerrar">✕</button>
  </div>
  <div class="visagismo-content">
    <div class="visagismo-header">
      <div class="gold-label" style="text-align:left;display:inline-block">VISAGISMO</div>
      <h2 class="visagismo-heading">Trabajamos con la forma de tu rostro.</h2>
      <p class="visagismo-sub">Cada corte es una decisión. Conocé tu tipo de rostro y descubrí qué estilos te favorecen.</p>
    </div>
    <div class="visagismo-grid" id="visagismoGrid">
      <div class="vf-card">
        <div class="vf-card-top">
          <div class="vf-card-left">
            <div class="vf-card-name">Ovalado</div>
            <img src="/galeria/formasDeCara/ovalada-removebg-preview.png" alt="Rostro ovalado" loading="lazy" />
          </div>
          <div class="vf-card-right">
            <div class="vf-feat-label">CARACTERÍSTICAS</div>
            <ul class="vf-feat-list">
              <li>Proporciones equilibradas</li>
              <li>Pómulos ligeramente marcados</li>
              <li>Frente y mandíbula similares</li>
              <li>Considerado el rostro ideal</li>
            </ul>
          </div>
        </div>
        <div class="vf-card-divider"></div>
        <div class="vf-cut-label">CORTES FAVORECIBLES</div>
        <div class="vf-cut-desc">La mayoría de los cortes funcionan. Podés experimentar con casi cualquier estilo, desde un buzz cut hasta un quiff o pompadour.</div>
        <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
        <div class="vf-expand-content">
          <div class="vf-expand-grid">
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg></div><div class="vf-haircut-name">Quiff</div><div class="vf-haircut-note">Volumen arriba, corto atrás</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg></div><div class="vf-haircut-name">Pompadour</div><div class="vf-haircut-note">Volumen alto y barrido</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg></div><div class="vf-haircut-name">Buzz Cut</div><div class="vf-haircut-note">Máquina, largo parejo</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg></div><div class="vf-haircut-name">Crop Top</div><div class="vf-haircut-note">Textura corta despeinada</div></div>
          </div>
        </div>
      </div>
      <div class="vf-card">
        <div class="vf-card-top">
          <div class="vf-card-left">
            <div class="vf-card-name">Cuadrado</div>
            <img src="/galeria/formasDeCara/cuadrada.jpeg" alt="Rostro cuadrado" loading="lazy" />
          </div>
          <div class="vf-card-right">
            <div class="vf-feat-label">CARACTERÍSTICAS</div>
            <ul class="vf-feat-list">
              <li>Mandíbula ancha y marcada</li>
              <li>Frente amplia</li>
              <li>Ángulos definidos</li>
              <li>Pómulos no muy resaltantes</li>
            </ul>
          </div>
        </div>
        <div class="vf-card-divider"></div>
        <div class="vf-cut-label">CORTES FAVORECIBLES</div>
        <div class="vf-cut-desc">Los cortes con volumen arriba y cortos en los costados equilibran la anchura. El Mod Cut y el Taper Fade alto son los mejores aliados.</div>
        <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
        <div class="vf-expand-content">
          <div class="vf-expand-grid">
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Mod Cut</div><div class="vf-haircut-note">Volumen arriba, lados cortos</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Taper Fade</div><div class="vf-haircut-note">Fade alto, volumen top</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Texturizado</div><div class="vf-haircut-note">Desconexión suave</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Undercut</div><div class="vf-haircut-note">Contraste fuerte arriba/abajo</div></div>
          </div>
        </div>
      </div>
      <div class="vf-card">
        <div class="vf-card-top">
          <div class="vf-card-left">
            <div class="vf-card-name">Redondo</div>
            <img src="/galeria/formasDeCara/redonda.jpeg" alt="Rostro redondo" loading="lazy" />
          </div>
          <div class="vf-card-right">
            <div class="vf-feat-label">CARACTERÍSTICAS</div>
            <ul class="vf-feat-list">
              <li>Cara ancha y sin ángulos</li>
              <li>Mejillas llenas</li>
              <li>Mentón redondeado</li>
              <li>Sin línea de mandíbula definida</li>
            </ul>
          </div>
        </div>
        <div class="vf-card-divider"></div>
        <div class="vf-cut-label">CORTES FAVORECIBLES</div>
        <div class="vf-cut-desc">Los cortes con altura en el top y fade en los costados alargan visualmente el rostro. Evitar volumen lateral.</div>
        <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
        <div class="vf-expand-content">
          <div class="vf-expand-grid">
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Fade Alto</div><div class="vf-haircut-note">Sube la línea visual</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Faux Hawk</div><div class="vf-haircut-note">Volumen central, lados fade</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Pompadour</div><div class="vf-haircut-note">Altura al frente</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Side Part</div><div class="vf-haircut-note">Raya marcada, estructura</div></div>
          </div>
        </div>
      </div>
      <div class="vf-card">
        <div class="vf-card-top">
          <div class="vf-card-left">
            <div class="vf-card-name">Rectangular</div>
            <img src="/galeria/formasDeCara/rectangular.jpeg" alt="Rostro rectangular" loading="lazy" />
          </div>
          <div class="vf-card-right">
            <div class="vf-feat-label">CARACTERÍSTICAS</div>
            <ul class="vf-feat-list">
              <li>Rostro largo y angosto</li>
              <li>Frente y mandíbula alineadas</li>
              <li>Laterales rectos</li>
              <li>Mentón bien definido</li>
            </ul>
          </div>
        </div>
        <div class="vf-card-divider"></div>
        <div class="vf-cut-label">CORTES FAVORECIBLES</div>
        <div class="vf-cut-desc">Cortes con volumen en los lados acortan visualmente el rostro. Evitar demasiado alto arriba.</div>
        <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
        <div class="vf-expand-content">
          <div class="vf-expand-grid">
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Texturizado</div><div class="vf-haircut-note">Volumen lateral suave</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">French Crop</div><div class="vf-haircut-note">Flequillo texturizado</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Side Part</div><div class="vf-haircut-note">Raya clásica, volumen</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Comb Over</div><div class="vf-haircut-note">Barrido lateral pulido</div></div>
          </div>
        </div>
      </div>
      <div class="vf-card">
        <div class="vf-card-top">
          <div class="vf-card-left">
            <div class="vf-card-name">Triangular</div>
            <img src="/galeria/formasDeCara/pera.jpeg" alt="Rostro triangular" loading="lazy" />
          </div>
          <div class="vf-card-right">
            <div class="vf-feat-label">CARACTERÍSTICAS</div>
            <ul class="vf-feat-list">
              <li>Mandíbula más ancha que la frente</li>
              <li>Pómulos prominentes</li>
              <li>Frente angosta</li>
              <li>Mentón amplio</li>
            </ul>
          </div>
        </div>
        <div class="vf-card-divider"></div>
        <div class="vf-cut-label">CORTES FAVORECIBLES</div>
        <div class="vf-cut-desc">Volumen en la parte superior agranda la frente visualmente. Fade en los costados reduce la anchura de la mandíbula.</div>
        <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
        <div class="vf-expand-content">
          <div class="vf-expand-grid">
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Quiff</div><div class="vf-haircut-note">Volumen arriba</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Pompadour</div><div class="vf-haircut-note">Altura al frente</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Volumen Top</div><div class="vf-haircut-note">Textura elevada</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Crop Fade</div><div class="vf-haircut-note">Crop texturizado + fade</div></div>
          </div>
        </div>
      </div>
      <div class="vf-card">
        <div class="vf-card-top">
          <div class="vf-card-left">
            <div class="vf-card-name">Corazón</div>
            <img src="/galeria/formasDeCara/corazon.jpeg" alt="Rostro corazón" loading="lazy" />
          </div>
          <div class="vf-card-right">
            <div class="vf-feat-label">CARACTERÍSTICAS</div>
            <ul class="vf-feat-list">
              <li>Frente ancha</li>
              <li>Pómulos altos</li>
              <li>Mandíbula angosta</li>
              <li>Mentón en punta</li>
            </ul>
          </div>
        </div>
        <div class="vf-card-divider"></div>
        <div class="vf-cut-label">CORTES FAVORECIBLES</div>
        <div class="vf-cut-desc">Cortes con volumen en la base y lados agregan amplitud a la mandíbula. Flequillo texturizado suaviza la frente.</div>
        <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
        <div class="vf-expand-content">
          <div class="vf-expand-grid">
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Taper</div><div class="vf-haircut-note">Volumen gradual en lados</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Textu. con Flequillo</div><div class="vf-haircut-note">Suaviza la frente</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Side Swept</div><div class="vf-haircut-note">Barrido lateral suave</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Ivy League</div><div class="vf-haircut-note">Elegante, versátil</div></div>
          </div>
        </div>
      </div>
      <div class="vf-card">
        <div class="vf-card-top">
          <div class="vf-card-left">
            <div class="vf-card-name">Diamante</div>
            <img src="/galeria/formasDeCara/diamante.jpeg" alt="Rostro diamante" loading="lazy" />
          </div>
          <div class="vf-card-right">
            <div class="vf-feat-label">CARACTERÍSTICAS</div>
            <ul class="vf-feat-list">
              <li>Pómulos muy marcados y anchos</li>
              <li>Frente y mandíbula angostas</li>
              <li>Forma romboidal</li>
              <li>Rostro anguloso</li>
            </ul>
          </div>
        </div>
        <div class="vf-card-divider"></div>
        <div class="vf-cut-label">CORTES FAVORECIBLES</div>
        <div class="vf-cut-desc">Volumen en frente y mandíbula equilibra los pómulos. Evitar cortes que den más volumen lateral.</div>
        <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
        <div class="vf-expand-content">
          <div class="vf-expand-grid">
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Ivy League</div><div class="vf-haircut-note">Pulido, volumen arriba</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Fringe</div><div class="vf-haircut-note">Flequillo texturizado</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Textured Crop</div><div class="vf-haircut-note">Desconexión natural</div></div>
            <div class="vf-haircut-card"><div class="vf-haircut-img"><svg viewBox="0 0 48 48" fill="none" stroke="rgba(240,236,228,.12)" stroke-width=".8"><circle cx="24" cy="16" r="10"></circle><path d="M8 44c0-8 7-14 16-14s16 6 16 14"></path></svg><!-- REPLACE WITH REAL HAIRCUT PHOTO --></div><div class="vf-haircut-name">Natural Flow</div><div class="vf-haircut-note">Largo natural, sin forzar</div></div>
          </div>
        </div>
      </div>
    </div>
  </div>
</div>
<style>
  #visagismoOverlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    z-index: 99998; background: var(--bg); display: none;
    opacity: 0; overflow-y: auto; flex-direction: column;
  }
  #visagismoOverlay.open { display: flex; opacity: 1; }
  .visagismo-overlay-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px var(--pad-m); flex-shrink: 0; border-bottom: 1px solid var(--border-subtle);
    position: sticky; top: 0; z-index: 10; background: var(--bg);
  }
  .visagismo-overlay-close {
    background: none; border: none; color: var(--muted); font-size: 26px; cursor: pointer;
    transition: color 0.3s ease, transform 0.4s ease;
    font-family: "DM Sans", sans-serif; line-height: 1; padding: 6px;
  }
  .visagismo-overlay-close:hover { color: var(--cream); transform: rotate(90deg); }
  #visagismoOverlay .visagismo-content { padding: 40px var(--pad-m) 80px; flex: 1; }
  @media (min-width: 768px) { #visagismoOverlay .visagismo-content { padding: 60px var(--pad-d) 80px; } }
  #visagismoOverlay .visagismo-header { text-align: center; margin-bottom: 48px; }
  #visagismoOverlay .visagismo-heading {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(44px, 6vw, 66px);
    font-weight: 600;
    color: var(--gold);
    text-align: center;
    line-height: 1.2;
    position: relative;
    padding-bottom: 12px;
    margin-bottom: 24px;
  }
  #visagismoOverlay .visagismo-heading::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 2px;
    background: var(--gold);
  }
  #visagismoOverlay .visagismo-sub {
    font-family: "DM Sans", sans-serif; font-size: 15px; color: var(--muted);
    text-align: center; max-width: 600px; margin: 0 auto 0; line-height: 1.7;
  }
  #visagismoOverlay .visagismo-grid { max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; gap: 16px; }
  .vf-card {
    background: var(--surface); border: 1px solid var(--border-subtle);
    border-top: 3px solid rgba(201,168,76,0.4);
    padding: 28px 24px 24px; position: relative; overflow: hidden; cursor: default;
    transition: transform 0.4s cubic-bezier(0.23,1,0.32,1), box-shadow 0.4s ease;
  }
