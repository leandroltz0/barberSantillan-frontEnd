---
---
<!-- === VISAGISMO OVERLAY === -->
<!-- Se muestra al hacer click en "Visagismo" del nav -->
<div id="visagismoOverlay">

  <!-- Header del overlay: logo + botón cerrar -->
  <header class="visagismo-overlay-header">
    <div class="header-logo"><img src="/logo.png" alt="Santillán" class="logo-img"></div>
    <button class="visagismo-overlay-close" id="visagismoClose" aria-label="Cerrar">✕</button>
  </header>

  <!-- Contenido principal scrolleable -->
  <div class="visagismo-content">

    <!-- Introducción de la sección -->
    <header class="visagismo-header">
      <div class="gold-label" style="text-align:left;display:inline-block">VISAGISMO</div>
      <h2 class="visagismo-heading">Trabajamos con la forma de tu rostro.</h2>
      <p class="visagismo-sub">Trabajamos con tu imagen a nivel profesional, ofreciendo una ayuda en base al visagismo. una tecnica que consiste en analisis de facciones,
        correccion optica, colorimetria, etc..
      </p>
    </header>

    <!-- Grid de cards: un article por cada tipo de rostro -->
    <div class="visagismo-grid" id="visagismoGrid">

      <!-- === CARD: OVALADO === -->
      <article class="vf-card">
        <header class="vf-card-head">
          <h3 class="vf-card-name">Ovalado</h3>
        </header>
        <section class="vf-card-body">
          <figure class="vf-card-illustration">
            <img src="/galeria/formasDeCara/ovalada-removebg-preview.png" alt="Ilustración de rostro ovalado" loading="lazy" />
          </figure>
          <div class="vf-card-features">
            <span class="vf-feat-label">Características</span>
            <ul class="vf-feat-list">
              <li>Proporciones equilibradas</li>
              <li>Pómulos ligeramente marcados</li>
              <li>Frente y mandíbula similares</li>
              <li>Considerado el rostro ideal</li>
            </ul>
          </div>
          <aside class="vf-card-tip">
            <span class="vf-tip-icon">✦</span>
            <p class="vf-tip-text">El más versátil: podés experimentar con casi cualquier estilo sin miedo.</p>
          </aside>
        </section>
        <hr class="vf-card-divider" />
        <section class="vf-card-cuts">
          <span class="vf-cut-label">Cortes favorecibles</span>
          <p class="vf-cut-desc">La mayoría de los cortes funcionan. Podés experimentar con casi cualquier estilo, desde un buzz cut hasta un quiff.</p>
          <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
          <div class="vf-expand-content">
            <div class="vf-expand-grid">
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/ovaldaFoto1.png" alt="Corte Pompadour para rostro ovalado" loading="lazy" /></div></figure>
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/ovalado2.jpg" alt="Corte Quiff para rostro ovalado" loading="lazy" /></div></figure>
            </div>
          </div>
        </section>
      </article>

      <!-- === CARD: CUADRADO === -->
      <article class="vf-card">
        <header class="vf-card-head">
          <h3 class="vf-card-name">Cuadrado</h3>
        </header>
        <section class="vf-card-body">
          <figure class="vf-card-illustration">
            <img src="/galeria/formasDeCara/cuadrada-removebg-preview.png" alt="Ilustración de rostro cuadrado" loading="lazy" />
          </figure>
          <div class="vf-card-features">
            <span class="vf-feat-label">Características</span>
            <ul class="vf-feat-list">
              <li>Mandíbula ancha y marcada</li>
              <li>Frente amplia</li>
              <li>Ángulos definidos</li>
              <li>Pómulos no muy resaltantes</li>
            </ul>
          </div>
          <aside class="vf-card-tip">
            <span class="vf-tip-icon">✦</span>
            <p class="vf-tip-text">Un degradado suave en los laterales realza la mandíbula sin endurecer las facciones.</p>
          </aside>
        </section>
        <hr class="vf-card-divider" />
        <section class="vf-card-cuts">
          <span class="vf-cut-label">Cortes favorecibles</span>
          <p class="vf-cut-desc">Los cortes con volumen arriba y cortos en los costados equilibran la anchura. El Mod Cut y el Taper Fade alto son los mejores.</p>
          <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
          <div class="vf-expand-content">
            <div class="vf-expand-grid">
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/cuadrada1.jpeg" alt="Corte Mod Cut para rostro cuadrado" loading="lazy" /></div></figure>
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/cuadrada2.jpeg" alt="Corte Taper Fade para rostro cuadrado" loading="lazy" /></div></figure>
            </div>
          </div>
        </section>
      </article>

      <!-- === CARD: REDONDO === -->
      <article class="vf-card">
        <header class="vf-card-head">
          <h3 class="vf-card-name">Redondo</h3>
        </header>
        <section class="vf-card-body">
          <figure class="vf-card-illustration">
            <img src="/galeria/formasDeCara/redonda-removebg-preview.png" alt="Ilustración de rostro redondo" loading="lazy" />
          </figure>
          <div class="vf-card-features">
            <span class="vf-feat-label">Características</span>
            <ul class="vf-feat-list">
              <li>Cara ancha y sin ángulos</li>
              <li>Mejillas llenas</li>
              <li>Mentón redondeado</li>
              <li>Sin línea de mandíbula definida</li>
            </ul>
          </div>
          <aside class="vf-card-tip">
            <span class="vf-tip-icon">✦</span>
            <p class="vf-tip-text">Evitá la raya al medio y los cortes muy simétricos: generan más redondez visual.</p>
          </aside>
        </section>
        <hr class="vf-card-divider" />
        <section class="vf-card-cuts">
          <span class="vf-cut-label">Cortes favorecibles</span>
          <p class="vf-cut-desc">Los cortes con altura en el top y fade en los costados alargan visualmente el rostro. Evitar volumen lateral.</p>
          <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
          <div class="vf-expand-content">
            <div class="vf-expand-grid">
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/redonda1.jpeg" alt="Corte Fade Alto para rostro redondo" loading="lazy" /></div></figure>
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/redonda2.jpeg" alt="Corte Faux Hawk para rostro redondo" loading="lazy" /></div></figure>
            </div>
          </div>
        </section>
      </article>

      <!-- === CARD: RECTANGULAR === -->
      <article class="vf-card">
        <header class="vf-card-head">
          <h3 class="vf-card-name">Rectangular</h3>
        </header>
        <section class="vf-card-body">
          <figure class="vf-card-illustration">
            <img src="/galeria/formasDeCara/rectangular-removebg-preview.png" alt="Ilustración de rostro rectangular" loading="lazy" />
          </figure>
          <div class="vf-card-features">
            <span class="vf-feat-label">Características</span>
            <ul class="vf-feat-list">
              <li>Rostro largo y angosto</li>
              <li>Frente y mandíbula alineadas</li>
              <li>Laterales rectos</li>
              <li>Mentón bien definido</li>
            </ul>
          </div>
          <aside class="vf-card-tip">
            <span class="vf-tip-icon">✦</span>
            <p class="vf-tip-text">Un flequillo texturizado ayuda a acortar visualmente el rostro y equilibrar proporciones.</p>
          </aside>
        </section>
        <hr class="vf-card-divider" />
        <section class="vf-card-cuts">
          <span class="vf-cut-label">Cortes favorecibles</span>
          <p class="vf-cut-desc">Cortes con volumen en los lados acortan visualmente el rostro. Evitar demasiado alto arriba.</p>
          <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
          <div class="vf-expand-content">
            <div class="vf-expand-grid">
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/rectangular1.jpeg" alt="Corte Texturizado para rostro rectangular" loading="lazy" /></div></figure>
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/rectangular2.jpeg" alt="Corte French Crop para rostro rectangular" loading="lazy" /></div></figure>
            </div>
          </div>
        </section>
      </article>

      <!-- === CARD: TRIANGULAR === -->
      <article class="vf-card">
        <header class="vf-card-head">
          <h3 class="vf-card-name">Triangular</h3>
        </header>
        <section class="vf-card-body">
          <figure class="vf-card-illustration">
            <img src="/galeria/formasDeCara/pera-removebg-preview.png" alt="Ilustración de rostro triangular" loading="lazy" />
          </figure>
          <div class="vf-card-features">
            <span class="vf-feat-label">Características</span>
            <ul class="vf-feat-list">
              <li>Mandíbula más ancha que la frente</li>
              <li>Pómulos prominentes</li>
              <li>Frente angosta</li>
              <li>Mentón amplio</li>
            </ul>
          </div>
          <aside class="vf-card-tip">
            <span class="vf-tip-icon">✦</span>
            <p class="vf-tip-text">El volumen arriba es clave: compensa la mandíbula ancha y equilibra el perfil.</p>
          </aside>
        </section>
        <hr class="vf-card-divider" />
        <section class="vf-card-cuts">
          <span class="vf-cut-label">Cortes favorecibles</span>
          <p class="vf-cut-desc">Volumen en la parte superior agranda la frente visualmente. Fade en los costados reduce la anchura de la mandíbula.</p>
          <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
          <div class="vf-expand-content">
            <div class="vf-expand-grid">
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/triangular1.jpg" alt="Corte Quiff para rostro triangular" loading="lazy" /></div></figure>
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/triangular2.jpeg" alt="Corte Pompadour para rostro triangular" loading="lazy" /></div></figure>
            </div>
          </div>
        </section>
      </article>

      <!-- === CARD: CORAZÓN === -->
      <article class="vf-card">
        <header class="vf-card-head">
          <h3 class="vf-card-name">Corazón</h3>
        </header>
        <section class="vf-card-body">
          <figure class="vf-card-illustration">
            <img src="/galeria/formasDeCara/corazon-removebg-preview.png" alt="Ilustración de rostro corazón" loading="lazy" />
          </figure>
          <div class="vf-card-features">
            <span class="vf-feat-label">Características</span>
            <ul class="vf-feat-list">
              <li>Frente ancha</li>
              <li>Pómulos altos</li>
              <li>Mandíbula angosta</li>
              <li>Mentón en punta</li>
            </ul>
          </div>
          <aside class="vf-card-tip">
            <span class="vf-tip-icon">✦</span>
            <p class="vf-tip-text">Cortes con peso en la mandíbula dan amplitud donde más se necesita.</p>
          </aside>
        </section>
        <hr class="vf-card-divider" />
        <section class="vf-card-cuts">
          <span class="vf-cut-label">Cortes favorecibles</span>
          <p class="vf-cut-desc">Cortes con volumen en la base y lados agregan amplitud a la mandíbula. Flequillo texturizado suaviza la frente.</p>
          <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
          <div class="vf-expand-content">
            <div class="vf-expand-grid">
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/corazon2.jpeg" alt="Corte Taper para rostro corazón" loading="lazy" /></div></figure>
            </div>
          </div>
        </section>
      </article>

      <!-- === CARD: DIAMANTE === -->
      <article class="vf-card">
        <header class="vf-card-head">
          <h3 class="vf-card-name">Diamante</h3>
        </header>
        <section class="vf-card-body">
          <figure class="vf-card-illustration">
            <img src="/galeria/formasDeCara/diamante-removebg-preview.png" alt="Ilustración de rostro diamante" loading="lazy" />
          </figure>
          <div class="vf-card-features">
            <span class="vf-feat-label">Características</span>
            <ul class="vf-feat-list">
              <li>Pómulos muy marcados y anchos</li>
              <li>Frente y mandíbula angostas</li>
              <li>Forma romboidal</li>
              <li>Rostro anguloso</li>
            </ul>
          </div>
          <aside class="vf-card-tip">
            <span class="vf-tip-icon">✦</span>
            <p class="vf-tip-text">Suavizá los pómulos con volumen en frente y mentón: esa es la estrategia principal.</p>
          </aside>
        </section>
        <hr class="vf-card-divider" />
        <section class="vf-card-cuts">
          <span class="vf-cut-label">Cortes favorecibles</span>
          <p class="vf-cut-desc">Volumen en frente y mandíbula equilibra los pómulos. Evitar cortes que den más volumen lateral.</p>
          <button class="vf-expand-btn" onclick="toggleVisagismo(this)">Ver cortes <span class="arrow">↓</span></button>
          <div class="vf-expand-content">
            <div class="vf-expand-grid">
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/diamond.jpeg" alt="Corte Ivy League para rostro diamante" loading="lazy" /></div></figure>
              <figure class="vf-haircut-card"><div class="vf-haircut-img"><img src="/galeria/visagismo/diamond2.jpeg" alt="Corte Fringe para rostro diamante" loading="lazy" /></div></figure>
            </div>
          </div>
        </section>
      </article>

    </div>
  </div>
</div>
<style>
  #visagismoOverlay {
    position: fixed; top: 0; left: 0; width: 100%; height: 100%;
    z-index: 99998; background: var(--bg); display: none;
    opacity: 0; overflow-y: auto; flex-direction: column;
  }
  #visagismoOverlay.open { display: flex; opacity: 1; }
  .visagismo-overlay-header {
    display: flex; align-items: center; justify-content: space-between;
    padding: 20px var(--pad-m); flex-shrink: 0; border-bottom: 1px solid var(--border-subtle);
    position: sticky; top: 0; z-index: 10; background: var(--bg);
  }
  .visagismo-overlay-close {
    background: none; border: none; color: var(--muted); font-size: 26px; cursor: pointer;
    transition: color 0.3s ease, transform 0.4s ease;
    font-family: "DM Sans", sans-serif; line-height: 1; padding: 6px;
  }
  .visagismo-overlay-close:hover { color: var(--cream); transform: rotate(90deg); }
  #visagismoOverlay .visagismo-content { padding: 40px var(--pad-m) 80px; flex: 1; }
  @media (min-width: 768px) { #visagismoOverlay .visagismo-content { padding: 60px var(--pad-d) 80px; } }
  #visagismoOverlay .visagismo-header { text-align: center; margin-bottom: 48px; }
  #visagismoOverlay .visagismo-heading {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(44px, 6vw, 66px);
    font-weight: 600;
    color: var(--gold);
    text-align: center;
    line-height: 1.2;
    position: relative;
    padding-bottom: 12px;
    margin-bottom: 24px;
  }
  #visagismoOverlay .visagismo-heading::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 2px;
    background: var(--gold);
  }
  #visagismoOverlay .visagismo-sub {
    font-family: "DM Sans", sans-serif; font-size: 15px; color: var(--muted);
    text-align: center; max-width: 600px; margin: 0 auto 0; line-height: 1.7;
  }
  #visagismoOverlay .visagismo-grid { max-width: 900px; margin: 0 auto; display: flex; flex-direction: column; gap: 16px; }
  .vf-card {
    background: var(--surface); border: 1px solid var(--border-subtle);
    border-top: 3px solid rgba(201,168,76,0.4);
    padding: 28px 24px 24px; position: relative; overflow: hidden; cursor: default;
    transition: transform 0.4s cubic-bezier(0.23,1,0.32,1), box-shadow 0.4s ease;
  }
  .vf-card:hover { transform: translateY(-4px); box-shadow: 0 20px 60px rgba(0,0,0,0.3); }
  .vf-card-head { display: flex; justify-content: space-between; align-items: center; margin-bottom: 16px; }
  .vf-card-name { font-family: "Cormorant Garamond", Georgia, serif; font-size: 26px; color: var(--cream); font-weight: 500; line-height: 1; padding-left: 60px; margin-top: -10px; }
  .vf-card-body { display: flex; gap: 20px; align-items: flex-start; }
  .vf-card-illustration { width: 25%; flex-shrink: 0; text-align: center; margin: 0; }
  .vf-card-illustration img { width: 100%; max-width: 200px; height: auto; display: block; margin: 0 auto; }
  .vf-card-features { flex: 1; min-width: 0; display: flex; flex-direction: column; gap: 8px; }
  /* Tip decorativo a la derecha de las características */
  .vf-card-tip {
    background: rgba(201, 168, 76, 0.04);
    border-left: 2px solid rgba(201, 168, 76, 0.25);
    padding: 16px 14px;
    border-radius: 0 4px 4px 0;
    display: none;
    flex-direction: column;
    gap: 8px;
    align-self: center;
    min-height: 120px;
    justify-content: center;
    mask-image: linear-gradient(to bottom, transparent, black 12%, black 88%, transparent);
    -webkit-mask-image: linear-gradient(to bottom, transparent, black 12%, black 88%, transparent);
  }
  .vf-tip-icon {
    font-size: 14px;
    color: var(--gold);
    opacity: 0.7;
  }
  .vf-tip-text {
    font-family: "DM Sans", sans-serif;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    font-style: italic;
    margin: 0;
  }
  .vf-feat-label {
    font-family: "DM Sans", sans-serif; font-size: 10px; font-weight: 600;
    letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold);
  }
  @media (min-width: 768px) {
    .vf-feat-label { font-size: 11px; border-left: 2px solid rgba(201,168,76,0.4); padding-left: 8px; }
  }
  .vf-feat-list { list-style: none; padding: 0; margin: 0; display: flex; flex-direction: column; gap: 4px; }
  @media (min-width: 768px) { .vf-feat-list { gap: 8px; } }
  .vf-feat-list li {
    font-family: "DM Sans", sans-serif; font-size: 15px; color: var(--cream);
    line-height: 1.75; position: relative; padding-left: 18px; opacity: 0.85;
  }
  @media (min-width: 768px) { .vf-feat-list li { font-size: 17px; padding-left: 22px; } }
  .vf-feat-list li::before { content: "—"; position: absolute; left: 0; color: var(--gold); opacity: 0.7; }
  /* Divider entre características y cortes */
  .vf-card-divider {
    width: 100%; height: 1px; background: var(--border-subtle);
    margin: 16px 0; border: none;
  }
  .vf-cut-label {
    font-family: "DM Sans", sans-serif; font-size: 10px; font-weight: 600;
    letter-spacing: 0.22em; text-transform: uppercase; color: var(--gold);
    margin-bottom: 8px; border-left: 2px solid rgba(201,168,76,0.4); padding-left: 8px;
  }
  .vf-cut-desc { font-family: "DM Sans", sans-serif; font-size: 14px; color: var(--muted); line-height: 1.75; }
  .vf-expand-btn {
    font-family: "DM Sans", sans-serif; font-size: 12px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--gold);
    background: transparent; border: none; cursor: pointer; padding: 10px 0;
    display: inline-flex; align-items: center; gap: 6px;
    transition: color 0.3s ease, gap 0.3s ease; margin-top: 12px;
  }
  .vf-expand-btn:hover { color: #d4b55e; gap: 10px; }
  .vf-expand-btn .arrow { display: inline-block; transition: transform 0.4s ease; }
  .vf-card.expanded .vf-expand-btn .arrow { transform: rotate(180deg); }
  .vf-expand-content { max-height: 0; overflow: hidden; transition: max-height 0.5s ease; padding-top: 0; }
  .vf-card.expanded .vf-expand-content { max-height: 2000px; padding-top: 16px; }
  .vf-expand-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 12px; }
  @media (min-width: 500px) { .vf-expand-grid { grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); } }
  .vf-haircut-card { background: #111; overflow: hidden; transition: transform 0.4s ease, box-shadow 0.4s ease; }
  .vf-haircut-card:hover { transform: translateY(-3px); box-shadow: 0 10px 30px rgba(0,0,0,0.3); }
  .vf-haircut-img { background: linear-gradient(145deg, #1a1a1a, #111); position: relative; overflow: hidden; padding-bottom: 110%; }
  .vf-haircut-img img { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; display: block; }

  .vf-icon-placeholder { width: 24px; height: 24px; opacity: 0.06; display: block; margin: 0 auto; }

  /* === RESPONSIVE: MOBILE === */
  @media (max-width: 767px) {
    .vf-card { overflow: visible; padding: 20px 16px 20px; }
    .vf-card-body { flex-direction: column; align-items: center; gap: 16px; }
    .vf-card-illustration { width: 100%; }
    .vf-card-illustration img { max-width: 160px; transform: none; }
    .vf-card-features { max-width: 100%; width: 100%; }
    .vf-card-tip { display: flex; width: 100%; }
    .vf-card-name { padding-left: 0; margin-top: 0; text-align: center; }
    .vf-card-head { flex-direction: column; gap: 8px; align-items: flex-start; }
  }

  /* === RESPONSIVE: TABLET === */
  @media (min-width: 768px) and (max-width: 1024px) {
    .vf-card-illustration img { max-width: 180px; }
    .vf-card-body { gap: 16px; }
    .vf-card-tip { display: flex; flex: 0 0 180px; margin-top: 3rem; }
  }

  /* === RESPONSIVE: DESKTOP === */
  @media (min-width: 1025px) {
    .vf-feat-list li { font-size: 19px; }
    .vf-feat-list { gap: 14px; }
    .vf-card-features { padding-top: 2rem; }
    .vf-card-tip { display: flex; flex: 0 0 220px; margin-top: 3rem; }
  }
</style>
