    </div>
    <div class="gallery-masonry">
      <div class="gallery-item" data-category="corte"><div class="gallery-item-inner"><div class="gallery-item-ph portrait"><img src="/galeria/corte/corte1.jpeg" alt="Corte 1" loading="lazy" /></div><span class="gallery-item-label">Corte</span></div></div>
