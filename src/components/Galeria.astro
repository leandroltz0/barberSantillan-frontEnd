      <div class="gallery-item" data-category="corte"><div class="gallery-item-inner"><div class="gallery-item-ph portrait"><img src="/galeria/corte/corte6.jpeg" alt="Corte 6" loading="lazy" /></div><span class="gallery-item-label">Corte</span></div></div>
