---
<section id="hero">
  <div class="hero-bg"><div class="hero-bg-img"></div></div>
  <div class="hero-ambient" id="heroAmbient">
    <canvas id="heroCanvas"></canvas>
  </div>
  <div class="hero-texture"></div>
  <div class="hero-overlay"></div>
  <div class="hero-content">
    <div class="hero-label" id="heroLabel">BIENVENIDO A SANTILLÁN</div>
    <div class="hero-line1" id="heroLine1">EL MEJOR CORTE</div>
    <div class="hero-line2" id="heroLine2"><span class="gold-box">SANTILLÁN</span></div>
    <div class="hero-line3" id="heroLine3">PARA TU MEJOR LOOK</div>
    <p class="hero-sub" id="heroSub">Barbería independiente, premium y auténtica. Moreno, Buenos Aires.</p>
    <div class="hero-cta" id="heroCta">
      <a href="https://wa.me/5491131920565" target="_blank" class="btn btn-primary">RESERVAR TURNO</a>
      <a href="#servicios" class="btn btn-secondary">VER SERVICIOS</a>
    </div>
  </div>
  <div class="hero-stats" id="heroStats">
    <div class="container">
      <div class="hero-stat"><div class="hero-stat-num" data-count="500">0+</div><div class="hero-stat-label">Clientes satisfechos</div></div>
      <div class="hero-stat"><div class="hero-stat-num" data-count="1">0</div><div class="hero-stat-label">Barbero experto</div></div>
      <div class="hero-stat"><div class="hero-stat-num">8AM – 10PM</div><div class="hero-stat-label">Todos los días</div></div>
      <div class="hero-stat"><div class="hero-stat-num">Moreno</div><div class="hero-stat-label">Buenos Aires</div></div>
    </div>
  </div>
</section>
