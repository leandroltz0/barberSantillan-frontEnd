<footer>
  <div class="container">
    <div class="footer-top">
      <div><div class="footer-logo"><img src="/logo.png" alt="Santillán" class="logo-img"></div></div>
      <nav class="footer-nav">
        <a href="#galeria">Galería</a><a href="#servicios">Servicios</a><a href="#nosotros">Nosotros</a><a href="#contacto">Contacto</a><a href="javascript:void(0)" onclick="openVisagismo()" style="color:#dc2626">Visagismo</a>
      </nav>
    </div>
    <div class="footer-mid">
      <div class="footer-mid-col"><label>UBICACIÓN</label><p>Martínez Melo 2420 · Moreno, Buenos Aires</p></div>
      <div class="footer-mid-col"><label>TURNO</label><p>WhatsApp directo · <a href="https://wa.me/5491131920565">+54 11 3192-0565</a></p></div>
      <div class="footer-mid-col"><label>REDES</label><p>@santillan.barber</p></div>
    </div>
    <div class="footer-divider"></div>
    <div class="footer-bottom">
      <p>© 2025 Santillán. Todos los derechos reservados.</p>
      <p>Moreno, Buenos Aires · Argentina</p>
    </div>
  </div>
</footer>
<style>
  footer { background: #080808; padding: 60px 0 32px; }
  .footer-top { display: flex; flex-direction: column; align-items: center; gap: 24px; text-align: center; }
  .footer-logo { font-family: "Cormorant Garamond", Georgia, serif; font-size: 22px; letter-spacing: 0.15em; color: var(--cream); }
  .footer-logo-underline { width: 60%; height: 1px; background: var(--gold); margin: 4px auto 0; }
  .footer-nav { display: flex; flex-wrap: wrap; justify-content: center; gap: 16px 24px; }
  .footer-nav a {
    font-family: "DM Sans", sans-serif; font-size: 12px; font-weight: 500;
    letter-spacing: 0.1em; text-transform: uppercase; color: var(--muted); transition: color 0.3s ease;
  }
  .footer-nav a:hover { color: var(--gold); }
  .footer-mid { display: flex; flex-direction: column; gap: 24px; margin-top: 40px; text-align: center; }
  .footer-mid-col label {
    font-family: "DM Sans", sans-serif; font-size: 10px; font-weight: 500;
    letter-spacing: 0.15em; text-transform: uppercase; color: var(--muted); display: block; margin-bottom: 6px;
  }
  .footer-mid-col p,
  .footer-mid-col a { font-family: "DM Sans", sans-serif; font-size: 13px; color: var(--cream); }
  .footer-mid-col a:hover { color: var(--gold); }
  .footer-divider { width: 100%; height: 1px; background: rgba(255,255,255,0.05); margin: 40px 0 24px; }
  .footer-bottom { display: flex; flex-direction: column; align-items: center; gap: 8px; text-align: center; }
  .footer-bottom p { font-family: "DM Sans", sans-serif; font-size: 12px; color: #444; }
  @media (min-width: 768px) {
    .footer-top { flex-direction: row; justify-content: space-between; text-align: left; }
    .footer-mid { flex-direction: row; justify-content: space-between; text-align: left; }
    .footer-bottom { flex-direction: row; justify-content: space-between; }
  }
</style>
