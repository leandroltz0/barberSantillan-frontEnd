<section id="por-que-elegirnos" class="section-padding">
  <div class="section-bridge top dark-to-surface"></div>
  <div class="container">
    <div class="why-grid">
      <div class="why-video" id="whyVideo">
        <button class="why-play" aria-label="Reproducir video"><svg viewBox="0 0 24 24"><polygon points="8,5 19,12 8,19"></polygon></svg></button>
        <span class="why-video-label">SANTILLÁN EN ACCIÓN</span>
      </div>
      <div class="why-right" id="whyRight">
        <h2 class="why-heading">La mejor experiencia de corte para todos los clientes.</h2>
        <div class="why-features" id="whyFeatures">
          <div class="why-feat-item"><i class="ph-thin ph-clock why-feature-icon"></i><div class="why-feature-label">EXPERIENCIA</div><div class="why-feature-text">Años perfeccionando cada corte</div></div>
          <div class="why-feat-item"><i class="ph-thin ph-user-circle why-feature-icon"></i><div class="why-feature-label">CERTIFICADO</div><div class="why-feature-text">Barbero profesional certificado</div></div>
          <div class="why-feat-item"><i class="ph-thin ph-camera why-feature-icon"></i><div class="why-feature-label">ESTILO PROPIO</div><div class="why-feature-text">Resultados instagrameables</div></div>
          <div class="why-feat-item"><i class="ph-thin ph-check-circle why-feature-icon"></i><div class="why-feature-label">CALIDAD</div><div class="why-feature-text">Satisfacción garantizada en cada visita</div></div>
        </div>
      </div>
    </div>
  </div>
