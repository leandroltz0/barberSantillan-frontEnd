---

<section id="por-que-elegirnos" class="section-padding">
  <div class="section-bridge top dark-to-surface"></div>
  <div class="container">
    <div class="why-grid">
      <div class="why-video" id="whyVideo">
        <div class="video-bg">
          <video src="/videos/video1.mp4" muted loop playsinline autoplay></video>
        </div>
        <div class="video-fg">
          <video src="/videos/video1.mp4" muted loop playsinline autoplay controls></video>
        </div>
        <span class="why-video-label"></span>
      </div>
      <div class="why-right" id="whyRight">
        <h2 class="why-heading">
          La mejor experiencia de corte para todos los clientes.
        </h2>
        
          <div class="why-feat-item">
            <i class="ph-thin ph-check-circle why-feature-icon"></i><div
              class="why-feature-label"
            >
              CALIDAD
            </div><div class="why-feature-text">
              Satisfacción garantizada en cada visita
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
<style>
  #por-que-elegirnos {
    background: var(--surface2);
  }
  .why-grid {
    display: flex;
    flex-direction: column;
    gap: 40px;
  }
  .why-video {
    position: relative;
    aspect-ratio: 3/4;
    background: #000;
    overflow: hidden;
    max-width: 100%;
  }
  .video-bg {
    position: absolute;
    inset: 0;
  }
  .video-bg video {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: blur(20px) brightness(0.25);
  }
  .video-fg {
    position: absolute;
    inset: 0;
    display: flex;
    justify-content: center;
    align-items: center;
  }
  .video-fg video {
    height: 100%;
    max-width: 100%;
  }
  .why-video-label {
    position: absolute;
    bottom: 12px;
    left: 16px;
    font-family: "DM Sans", sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--muted);
  }
  .why-heading {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(40px, 5.5vw, 56px);
    font-weight: 600;
    color: var(--gold);
    line-height: 1.2;
    position: relative;
    padding-bottom: 12px;
    margin-bottom: 28px;
  }
  .why-heading::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 0;
    width: 60px;
    height: 2px;
    background: var(--gold);
  }
  .why-features {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 24px;
  }
  .why-feature-icon {
    font-size: 24px;
    color: var(--gold);
    margin-bottom: 6px;
    display: block;
    line-height: 1;
  }
  .why-feature-label {
    font-family: "DM Sans", sans-serif;
    font-size: 11px;
    font-weight: 500;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--muted);
    margin-bottom: 4px;
  }
  .why-feature-text {
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    color: var(--cream);
  }
  @media (min-width: 768px) {
    .why-grid {
      flex-direction: row;
      align-items: center;
    }
    .why-video {
      flex: 1;
      max-width: 50%;
    }
    .why-right {
      flex: 1;
    }
  }
</style>
