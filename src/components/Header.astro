---
---
<header id="header">
  <div class="container">
    <a href="#hero" class="header-logo"><img src="/logo.png" alt="Santillán" class="logo-img"></a>
    <nav class="desktop-nav">
      <a href="#galeria">Galería</a>
      <a href="#servicios">Servicios</a>
      <a href="#nosotros">Nosotros</a>
      <a href="#contacto">Contacto</a>
      <a href="javascript:void(0)" onclick="openVisagismo()" class="nav-visagismo">Visagismo</a>
    </nav>
    <button class="hamburger" id="hamburger" aria-label="Menú"><span></span><span></span><span></span></button>
  </div>
</header>

<div class="mobile-overlay" id="mobileOverlay">
  <div class="mobile-overlay-bg"></div>
  <div class="mobile-overlay-noise"></div>
  <div class="mobile-overlay-glow"></div>
  <div class="mobile-header">
    <a href="#hero" class="mobile-logo" onclick="closeMobileMenu()"><img src="/logo.png" alt="Santillán" class="logo-img" style="height: 80px; width: auto;"></a>
    <button class="mobile-close" id="mobileClose" aria-label="Cerrar" onclick="closeMobileMenu()">
      <svg width="36" height="36" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  
  <div class="mobile-nav-content">
    <div class="mobile-nav-links">
      <a href="#galeria" onclick="closeMobileMenu()">
        <span class="nav-num">01</span>
        <span class="nav-text">Galería</span>
      </a>
      <a href="#servicios" onclick="closeMobileMenu()">
        <span class="nav-num">02</span>
        <span class="nav-text">Servicios</span>
      </a>
      <a href="#nosotros" onclick="closeMobileMenu()">
        <span class="nav-num">03</span>
        <span class="nav-text">Nosotros</span>
      </a>
      <a href="#contacto" onclick="closeMobileMenu()">
        <span class="nav-num">04</span>
        <span class="nav-text">Contacto</span>
      </a>
      <a href="javascript:void(0)" onclick="closeMobileMenu(); setTimeout(openVisagismo, 400)" class="mobile-nav-visagismo">
        <span class="nav-num">05</span>
        <span class="nav-text">Visagismo</span>
      </a>
    </div>
    
    <div class="mobile-nav-footer">
      <div class="mobile-nav-tagline">Estilo que transforma.</div>
      <div class="mobile-nav-bottom-row">
        <p class="mobile-nav-address">Mitre 123, Moreno, Buenos Aires<br>Turnos: +54 9 11 1234-5678</p>
        <div class="mobile-nav-socials">
          <a href="#" aria-label="Instagram"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
          <a href="#" aria-label="WhatsApp"><svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg></a>
        </div>
      </div>
    </div>
  </div>
</div>

<style>
  header {
    position: fixed;
    top: 0;
    left: 0;
    height: 5rem;
    width: 100%;
    z-index: 50000;
    padding: 2px var(--pad-m);
    background: rgba(13,13,13,0.22);
    backdrop-filter: blur(36px) saturate(1.7);
    -webkit-backdrop-filter: blur(36px) saturate(1.7);
    box-shadow: 0 1px 0 rgba(201,168,76,0.08);
    transition: background 0.4s ease;
  }
  header.scrolled { background: rgba(13,13,13,0.72); }
  header .container {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }
  nav {
    display: flex;
    align-items: center;
    gap: 32px;
  }
  nav a {
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    font-weight: 500;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--muted);
    position: relative;
    padding: 8px 12px;
    border-radius: 4px;
    transition: color 0.4s cubic-bezier(0.23,1,0.32,1), transform 0.4s cubic-bezier(0.23,1,0.32,1), text-shadow 0.4s ease;
  }
  nav a:hover {
    color: var(--cream);
    transform: translateY(-2px);
    text-shadow: 0 0 12px rgba(201,168,76,0.4);
  }
  nav a::before {
    content: "";
    position: absolute;
    inset: 0;
    border-radius: 4px;
    background: radial-gradient(ellipse at bottom, rgba(201,168,76,0.15) 0%, transparent 70%);
    opacity: 0;
    transform: translateY(4px);
    transition: transform 0.4s cubic-bezier(0.23,1,0.32,1), opacity 0.4s ease;
    pointer-events: none;
  }
  nav a:hover::before { transform: translateY(0); opacity: 1; }
  nav a::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 12px;
    width: calc(100% - 24px);
    height: 2px;
    background: var(--gold);
    transform: scaleX(0);
    transform-origin: right;
    transition: transform 0.4s cubic-bezier(0.23,1,0.32,1);
    box-shadow: 0 2px 8px rgba(201,168,76,0.4);
  }
  nav a:hover::after { transform: scaleX(1); transform-origin: left; }
  nav a.nav-visagismo { color: #dc2626; font-weight: 700; }
  nav a.nav-visagismo:hover { color: #ef4444; }
  nav a.nav-visagismo::after { background: #dc2626; }
  nav a.nav-visagismo::before { background: rgba(220,38,38,0.12); }
  .hamburger {
    display: none;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-right: 14px;
  }
  .hamburger span {
    display: block;
    width: 24px;
    height: 2px;
    background: var(--cream);
    transition: transform 0.3s ease, opacity 0.3s ease;
  }
  .hamburger.active span:nth-child(1) { transform: translateY(7px) rotate(45deg); }
  .hamburger.active span:nth-child(2) { opacity: 0; }
  .hamburger.active span:nth-child(3) { transform: translateY(-7px) rotate(-45deg); }
  .mobile-overlay {
    display: none;
    position: fixed;
    inset: 0;
    z-index: 60000;
    background: #080808;
    flex-direction: column;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.4s ease, visibility 0.4s;
    clip-path: circle(0% at 100% 0%);
  }
  .mobile-overlay.open { display: flex; opacity: 1; visibility: visible; }
  .mobile-overlay-noise {
    position: absolute;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='nf'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23nf)'/%3E%3C/svg%3E");
    opacity: 0.03;
    pointer-events: none;
    z-index: 0;
  }
  .mobile-overlay-glow {
    position: absolute;
    top: -10%;
    right: -10%;
    width: 70vw;
    height: 70vw;
    background: radial-gradient(circle, var(--gold) 0%, transparent 70%);
    opacity: 0.08;
    pointer-events: none;
    z-index: 0;
  }
  .mobile-header {
    position: relative;
    z-index: 2;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 12px var(--pad-m);
  }
  .mobile-close {
    background: none;
    border: none;
    color: var(--cream);
    display: flex;
    align-items: center;
    justify-content: center;
    width: 48px;
    height: 48px;
    cursor: pointer;
    transition: color 0.3s, transform 0.4s ease;
    margin-right: 2px;
  }
  .mobile-close:hover { color: var(--gold); transform: rotate(45deg); }
  .mobile-nav-content {
    position: relative;
    z-index: 2;
    flex: 1;
    display: flex;
    flex-direction: column;
    padding: 20px var(--pad-m) 40px;
    overflow-y: auto;
  }
  .mobile-nav-links {
    display: flex;
    flex-direction: column;
    margin-top: 20px;
  }
  .mobile-nav-links a {
    display: flex;
    align-items: center;
    gap: 20px;
    text-decoration: none;
    padding: 24px 0;
    border-bottom: 1px solid rgba(255,255,255,0.06);
    position: relative;
    opacity: 0;
    transform: translateY(20px);
  }
  .nav-num {
    font-family: "JetBrains Mono", "DM Sans", monospace;
    font-size: 12px;
    font-weight: 400;
    color: var(--cream);
    opacity: 0.3;
    margin-top: 6px;
  }
  .nav-text {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 52px;
    color: #F0EDE8;
    line-height: 1;
    transition: color 0.3s ease, transform 0.4s cubic-bezier(0.23,1,0.32,1);
    position: relative;
  }
  .mobile-nav-links a::before {
    content: "";
    position: absolute;
    left: 36px;
    top: 50%;
    transform: translateY(-50%) scaleX(0);
    transform-origin: left;
    width: 24px;
    height: 1px;
    background: var(--gold);
    transition: transform 0.4s cubic-bezier(0.23,1,0.32,1);
    opacity: 0;
  }
  .mobile-nav-links a:hover .nav-text { color: var(--gold); transform: translateX(36px); }
  .mobile-nav-links a:hover::before { transform: translateY(-50%) scaleX(1); opacity: 1; }
  .mobile-nav-visagismo .nav-text { color: #dc2626; }
  .mobile-nav-visagismo:hover .nav-text { color: #ef4444; }
  .mobile-nav-visagismo::before { background: #ef4444; }
  .mobile-nav-footer {
    margin-top: auto;
    padding-top: 60px;
    opacity: 0;
    transform: translateY(20px);
  }
  .mobile-nav-tagline {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-style: italic;
    font-size: 20px;
    color: var(--muted);
    margin-bottom: 32px;
  }
  .mobile-nav-bottom-row {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
  }
  .mobile-nav-address {
    font-family: "DM Sans", sans-serif;
    font-size: 13px;
    color: var(--muted);
    line-height: 1.6;
    opacity: 0.8;
  }
  .mobile-nav-socials { display: flex; gap: 24px; }
  .mobile-nav-socials a {
    color: var(--cream);
    opacity: 0.8;
    transition: color 0.3s, transform 0.3s, opacity 0.3s;
  }
  .mobile-nav-socials a svg { width: 24px; height: 24px; }
  .mobile-nav-socials a:hover { color: var(--gold); opacity: 1; transform: translateY(-3px); }
  @media (max-width: 767px) {
    nav.desktop-nav { display: none; }
    .hamburger { display: flex; }
    header { padding: 4px var(--pad-m); }
  }
  @media (min-width: 768px) {
    .mobile-overlay { display: none !important; }
    .hamburger { display: none !important; }
  }
</style>
<script>
  let mobileOverlayTl;
  
  function initMobileMenu() {
    const hamburger = document.getElementById('hamburger');
    const overlay = document.getElementById('mobileOverlay');
    const links = document.querySelectorAll('.mobile-nav-links a');
    const footer = document.querySelector('.mobile-nav-footer');
    
    // Check if gsap is available
    if (typeof gsap === 'undefined') return;
    
    mobileOverlayTl = gsap.timeline({ paused: true })
      .to(overlay, { 
        clipPath: 'circle(150% at 100% 0%)', 
        duration: 0.8, 
        ease: 'power3.inOut' 
      })
      .to(links, {
        y: 0,
        opacity: 1,
        duration: 0.6,
        stagger: 0.08,
        ease: 'power3.out'
      }, "-=0.4")
      .to(footer, {
        y: 0,
        opacity: 1,
        duration: 0.6,
        ease: 'power3.out'
      }, "-=0.4");
      
    hamburger.addEventListener('click', () => {
      overlay.classList.add('open');
      mobileOverlayTl.timeScale(1).play();
      document.body.style.overflow = 'hidden';
    });
  }
  
  window.closeMobileMenu = function() {
    const overlay = document.getElementById('mobileOverlay');
    if (mobileOverlayTl) {
      mobileOverlayTl.timeScale(1.5).reverse().then(() => {
        overlay.classList.remove('open');
        document.body.style.overflow = '';
      });
    } else {
      overlay.classList.remove('open');
      document.body.style.overflow = '';
    }
  };
  
  // Initialize on load and view transitions
  initMobileMenu();
  document.addEventListener('astro:page-load', initMobileMenu);
</script>
