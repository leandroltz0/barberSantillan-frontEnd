---
---
<header id="header">
  <div class="container">
    <a href="#hero" class="header-logo"><img src="/logo.png" alt="Santillán" class="logo-img"></a>
    <nav class="desktop-nav">
      <a href="#galeria">Galería</a>
      <a href="#servicios">Servicios</a>
      <a href="#nosotros">Nosotros</a>
      <a href="#contacto">Contacto</a>
      <a href="javascript:void(0)" onclick="openVisagismo()" class="nav-visagismo">Visagismo</a>
    </nav>
    <button class="hamburger" id="hamburger" aria-label="Menú"><span></span><span></span><span></span></button>
  </div>
</header>

<div class="mobile-overlay" id="mobileOverlay">
  <div class="mobile-overlay-bg"></div>
  <div class="mobile-header">
    <a href="#hero" class="mobile-logo" onclick="document.getElementById('mobileClose').click()"><img src="/logo.png" alt="Santillán" class="logo-img" style="height: 40px; width: auto;"></a>
    <button class="mobile-close" id="mobileClose" aria-label="Cerrar">
      <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
    </button>
  </div>
  
  <div class="mobile-nav-content">
    <div class="mobile-nav-links">
      <a href="#galeria">
        <span class="nav-num">01</span>
        <span class="nav-text">Galería</span>
      </a>
      <a href="#servicios">
        <span class="nav-num">02</span>
        <span class="nav-text">Servicios</span>
      </a>
      <a href="#nosotros">
        <span class="nav-num">03</span>
        <span class="nav-text">Nosotros</span>
      </a>
      <a href="#contacto">
        <span class="nav-num">04</span>
        <span class="nav-text">Contacto</span>
      </a>
      <a href="javascript:void(0)" onclick="openVisagismo()" class="mobile-nav-visagismo">
        <span class="nav-num">05</span>
        <span class="nav-text">Visagismo</span>
      </a>
    </div>
    
    <div class="mobile-nav-footer">
      <p class="mobile-nav-address">Mitre 123, Moreno, Buenos Aires<br>Turnos: +54 9 11 1234-5678</p>
      <div class="mobile-nav-socials">
        <a href="#" aria-label="Instagram"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line x1="17.5" y1="6.5" x2="17.51" y2="6.5"></line></svg></a>
        <a href="#" aria-label="WhatsApp"><svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M21 11.5a8.38 8.38 0 0 1-.9 3.8 8.5 8.5 0 0 1-7.6 4.7 8.38 8.38 0 0 1-3.8-.9L3 21l1.9-5.7a8.38 8.38 0 0 1-.9-3.8 8.5 8.5 0 0 1 4.7-7.6 8.38 8.38 0 0 1 3.8-.9h.5a8.48 8.48 0 0 1 8 8v.5z"></path></svg></a>
      </div>
    </div>
  </div>
</div>
