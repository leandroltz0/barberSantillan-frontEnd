---

---

<section id="servicios" class="section-padding">
  <div class="section-bridge top dark-to-surface"></div>
  <div class="container">
    <div class="services-header">
      <div class="gold-label">SERVICIOS</div>
      <h2 class="services-heading">Nuestros Servicios</h2>
      <p class="services-sub">
        Ofrezco una gama completa de servicios de barbería para dejarte
        impecable.
      </p>
    </div>
    <div class="services-grid">
      <div class="service-card">
        <div class="service-card-content">
          <i class="ph-thin ph-scissors service-icon"></i>
          <h3 class="service-name">Corte normal</h3>
          <p class="service-desc">
            Corte clásico con tijera y máquina. Rápido, prolijo y económico.
          </p>
          <span class="service-price">$8.000</span>
        </div>
        <div class="service-image-wrap">
          <div class="service-image-placeholder"><img src="/galeria/corte/corte1.jpeg" alt="Corte normal" loading="lazy" /></div>
          <div class="service-image-overlay"></div>
          <div class="service-image-border"></div>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card-content">
          <i class="ph-thin ph-knife service-icon"></i>
          <h3 class="service-name">Corte franja</h3>
          <p class="service-desc">
            Corte clásico con tijera y máquina. Definido y prolijo.
          </p>
          <span class="service-price">$18.000</span>
        </div>
        <div class="service-image-wrap">
          <div class="service-image-placeholder"><img src="/galeria/franja/franja1.jpeg" alt="Corte franja" loading="lazy" /></div>
          <div class="service-image-overlay"></div>
          <div class="service-image-border"></div>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card-content">
          <i class="ph-thin ph-paint-brush service-icon"></i>
          <h3 class="service-name">Claritos</h3>
          <p class="service-desc">
            Mechas y técnica de decoloración. Natural y con fachero.
          </p>
          <span class="service-price">$28.000</span>
        </div>
        <div class="service-image-wrap">
          <div class="service-image-placeholder"><img src="/galeria/claritos/claritos1.jpeg" alt="Claritos" loading="lazy" /></div>
          <div class="service-image-overlay"></div>
          <div class="service-image-border"></div>
        </div>
      </div>
      <div class="service-card">
        <div class="service-card-content">
          <i class="ph-thin ph-drop-half service-icon"></i>
          <h3 class="service-name">Global</h3>
          <p class="service-desc">
            Coloración completa. Resultado profesional, duración garantizada.
          </p>
          <span class="service-price">$35.000</span>
        </div>
        <div class="service-image-wrap">
          <div class="service-image-placeholder"><img src="/galeria/global/global1.jpeg" alt="Global" loading="lazy" /></div>
          <div class="service-image-overlay"></div>
          <div class="service-image-border"></div>
        </div>
      </div>
    </div>
  </div>
</section>
<style>
  #servicios {
    background: var(--surface2);
  }
  .services-header {
    text-align: center;
    margin-bottom: 48px;
  }
  .services-header .gold-label {
    display: inline-block;
    border-left: 2px solid var(--gold);
    margin-bottom: 12px;
  }
  .services-heading {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: clamp(44px, 6vw, 66px);
    font-weight: 600;
    color: var(--gold);
    line-height: 1.2;
    position: relative;
    padding-bottom: 12px;
    margin: 0 0 24px;
  }
  .services-heading::after {
    content: "";
    position: absolute;
    bottom: 0;
    left: 50%;
    transform: translateX(-50%);
    width: 60px;
    height: 2px;
    background: var(--gold);
  }
  .services-sub {
    font-family: "DM Sans", sans-serif;
    font-size: 15px;
    color: var(--muted);
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }
  .services-grid {
    display: grid;
    grid-template-columns: 1fr;
    gap: 28px;
  }
  @media (min-width: 768px) {
    .services-grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }
  .service-card {
    background: var(--bg);
    padding: 32px 24px 0;
    border-top: 3px solid transparent;
    transition:
      transform 0.35s ease,
      border-color 0.35s ease;
  }
  .service-card:hover {
    transform: translateY(-6px);
    border-top-color: var(--gold);
  }
  .service-card:nth-child(1) {
    transition-delay: 0ms;
  }
  .service-card:nth-child(2) {
    transition-delay: 100ms;
  }
  .service-card:nth-child(3) {
    transition-delay: 200ms;
  }
  .service-card:nth-child(4) {
    transition-delay: 300ms;
  }
  .service-card-content {
    padding-bottom: 24px;
  }
  .service-icon {
    font-size: 48px;
    color: #c9a84c;
    display: block;
    text-align: center;
    margin-bottom: 20px;
    line-height: 1;
  }
  .service-name {
    font-family: "Cormorant Garamond", Georgia, serif;
    font-size: 26px;
    color: var(--cream);
    margin-bottom: 8px;
    font-weight: 500;
  }
  .service-desc {
    font-family: "DM Sans", sans-serif;
    font-size: 13px;
    color: var(--muted);
    max-width: 260px;
    line-height: 1.6;
    margin-bottom: 16px;
  }
  .service-price {
    display: inline-block;
    font-family: "DM Sans", sans-serif;
    font-size: 13px;
    font-weight: 500;
    color: var(--gold);
    border: 1px solid var(--gold);
    padding: 6px 16px;
  }
  .service-image-wrap {
    position: relative;
    width: 100%;
    aspect-ratio: 1/1;
    overflow: hidden;
    cursor: pointer;
  }
  .service-image-placeholder {
    width: 100%;
    height: 100%;
    background: #1c1c1c;
    overflow: hidden;
    transition: transform 0.5s ease;
  }
  .service-image-placeholder img {
    width: 100%; height: 100%; object-fit: cover; display: block;
  }
  .service-image-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      to top,
      rgba(201, 168, 76, 0.2),
      transparent 60%
    );
    opacity: 0;
    transition: opacity 0.4s ease;
  }
  .service-image-border {
    position: absolute;
    bottom: 0;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--gold);
    transition: width 0.4s ease;
  }
  .service-card:hover .service-image-placeholder {
    transform: scale(1.08);
  }
  .service-card:hover .service-image-overlay {
    opacity: 1;
  }
  .service-card:hover .service-image-border {
    width: 100%;
  }
  .services-bottom {
    text-align: center;
    margin-top: 5rem;
  }
  .services-bottom p {
    font-family: "DM Sans", sans-serif;
    font-size: 14px;
    color: var(--muted);
    margin-bottom: 20px;
    line-height: 1.5;
  }
</style>
