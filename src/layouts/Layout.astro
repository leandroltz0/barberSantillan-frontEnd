---
import '../styles/global.css';

const {
  title = "Santillán · Barbería Premium · Moreno, Buenos Aires",
  description = "Barbería independiente, premium y auténtica. Moreno, Buenos Aires.",
} = Astro.props;
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta
      name="viewport"
      content="width=device-width, initial-scale=1, minimum-scale=1, maximum-scale=1, user-scalable=no, viewport-fit=cover"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta
      name="keywords"
      content="barbero Moreno, corte de pelo Moreno Buenos Aires, barbería Santillán"
    />
    <link rel="icon" href="/browser-logo.png" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:ital,wght@0,300;0,400;0,500;0,600;1,300;1,400;1,500;1,600&family=DM+Sans:wght@400;500;700&display=swap"
      rel="stylesheet"
    />
    <link
      rel="stylesheet"
      href="https://cdn.jsdelivr.net/npm/@phosphor-icons/web@2.1.2/src/thin/style.css"
    />
    <script is:inline src="https://unpkg.com/gsap@3.15.0/dist/gsap.min.js"></script>
    <script is:inline src="https://unpkg.com/gsap@3.15.0/dist/ScrollTrigger.min.js"></script>
  </head>
  <body>
    <slot />
    <script is:inline src="/main.js"></script>
  </body>
</html>
