---
import Layout from '../layouts/Layout.astro';
import Loader from '../components/Loader.astro';
import Header from '../components/Header.astro';
import Hero from '../components/Hero.astro';
import About from '../components/About.astro';
import Certificacion from '../components/Certificacion.astro';
import Servicios from '../components/Servicios.astro';
import SocialProof from '../components/SocialProof.astro';
import Galeria from '../components/Galeria.astro';
import CortesOverlay from '../components/CortesOverlay.astro';
import WhyChooseUs from '../components/WhyChooseUs.astro';
import Contacto from '../components/Contacto.astro';
import Footer from '../components/Footer.astro';
import CortesFloat from '../components/CortesFloat.astro';
import Visagismo from '../components/Visagismo.astro';
import WhatsAppFloat from '../components/WhatsAppFloat.astro';
---

<Layout>
  <Loader />
  <Header />
  
  <main>
    <Hero />
    <About />
    <Certificacion />
    <Servicios />
    <SocialProof />
    <Galeria />
    <WhyChooseUs />
    <Contacto />
  </main>
  
  <Footer />
  
  <!-- Overlays y flotantes -->
  <CortesOverlay />
  <Visagismo />
  <CortesFloat />
  <WhatsAppFloat />
</Layout>
